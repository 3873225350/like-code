{
  "env": {
    "ANTHROPIC_AUTH_TOKEN": "YOUR_TOKEN",
    "ANTHROPIC_BASE_URL": "https://api.minimaxi.com/anthropic",
    "API_TIMEOUT_MS": "3000000",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "glm-5-turbo",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "glm-5.1",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "MiniMax-M2.7",
    "ANTHROPIC_MODEL": "glm-5-turbo"
  },
  "permissions": {
    "allow": [
      "Bash(python3 -m py_compile <PROJECT_PATH>/src/commands/usemodel/snake_launcher.py)",
      "mcp__codex__codex",
      "Bash(python3 -m py_compile <PROJECT_PATH>/templete/v1/snake_main.py)",
      "Bash(python3 -m py_compile snake_engine.py snake_main.py)"
