{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "cc-route",
  "version": "1.0.0",
  "identifier": "com.cc-route.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "cc-route",
        "width": 900,
        "height": 650,
        "resizable": true,
        "visible": false,
        "decorations": true,
        "center": true,
        "skipTaskbar": false
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default"]
    },
    "withGlobalTauri": false
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/cc-route-proxy"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
