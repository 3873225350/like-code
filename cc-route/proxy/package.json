{
  "name": "cc-route-proxy",
  "version": "1.0.0",
  "description": "HTTP proxy for routing Claude Code requests to multiple LLM providers (Anthropic, MiniMax, GLM, DeepSeek, Kimi)",
  "main": "dist/index.js",
  "bin": {
    "cc-route-proxy": "dist/index.js",
    "clauder": "dist/clauder.js"
  },
  "files": [
    "dist/**/*",
    "package.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "compile": "bun build --compile --outfile ../release/cc-route-proxy src/index.ts",
    "compile:all": "node ../scripts/build-all.js --all",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "claude-code",
    "proxy",
    "multi-provider",
    "model-routing",
    "anthropic",
    "minimax",
    "glm",
    "deepseek",
    "kimi"
  ],
  "author": "harzva <626609967@qq.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/3873225350/cc-route.git",
    "directory": "proxy"
  },
  "dependencies": {
    "chokidar": "^4.0.0",
    "prom-client": "^15.1.3",
    "undici": "^7.0.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20"
  }
}
